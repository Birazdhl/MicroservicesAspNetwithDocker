name: dockercompose11062501626633180404
services:
  mongodb-container:
    image: mongo:latest
    networks:
      orders-mongodb-network: null
    ports:
      - mode: ingress
        target: 27017
        published: "27017"
        protocol: tcp
    volumes:
      - type: bind
        source: B:\Programming\Microservices\Self Practice\OrderMicroservice\OrdersMicroservice.API\mongodb-init
        target: /docker-entrypoint-initdb.d
        bind: {}
  mysql-container:
    environment:
      MYSQL_ROOT_PASSWORD: admin
    image: mysql:8.0
    networks:
      products-mysql-network: null
    ports:
      - mode: ingress
        target: 3306
        published: "3307"
        protocol: tcp
    volumes:
      - type: bind
        source: B:\Programming\Microservices\Self Practice\OrderMicroservice\OrdersMicroservice.API\mysql-init
        target: /docker-entrypoint-initdb.d
        bind: {}
  ordersmicroservice.api:
    build:
      context: B:\Programming\Microservices\Self Practice\OrderMicroservice
      dockerfile: OrdersMicroservice.API/Dockerfile
      args:
        BUILD_CONFIGURATION: Debug
        LAUNCHING_FROM_VS: "true"
      labels:
        com.microsoft.created-by: visual-studio
        com.microsoft.visual-studio.project-name: OrdersMicroservice.API
      target: base
    depends_on:
      mongodb-container:
        condition: service_started
        required: true
    entrypoint:
      - dotnet
      - --roll-forward
      - Major
      - /VSTools/DistrolessHelper/DistrolessHelper.dll
      - --wait
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      ASPNETCORE_HTTPS_PORTS: "8081"
      ASPNETCORE_LOGGING__CONSOLE__DISABLECOLORS: "true"
      DOTNET_USE_POLLING_FILE_WATCHER: "1"
      MONGODB_DATABASE: OrdersDatabase
      MONGODB_HOST: mongodb-container
      MONGODB_PORT: "27017"
      NUGET_FALLBACK_PACKAGES: /.nuget/fallbackpackages
      ProductsMicroserviceName: products-microservice
      ProductsMicroservicePort: "8080"
      UsersMicroserviceName: users-microservice
      UsersMicroservicePort: "9090"
    image: ordersmicroserviceapi:dev
    labels:
      com.microsoft.visualstudio.debuggee.arguments: ' --additionalProbingPath /.nuget/packages --additionalProbingPath /.nuget/fallbackpackages  "/app/bin/Debug/net8.0/OrdersMicroservice.API.dll"'
      com.microsoft.visualstudio.debuggee.killprogram: dotnet --roll-forward Major /VSTools/DistrolessHelper/DistrolessHelper.dll --stop dotnet
      com.microsoft.visualstudio.debuggee.program: dotnet
      com.microsoft.visualstudio.debuggee.workingdirectory: /app
    networks:
      ecommerce-network: null
      orders-mongodb-network: null
    ports:
      - mode: ingress
        target: 8080
        published: "7000"
        protocol: tcp
      - mode: ingress
        target: 8080
        protocol: tcp
      - mode: ingress
        target: 8081
        protocol: tcp
    tty: true
    volumes:
      - type: bind
        source: C:\Users\biraz\AppData\Roaming\Microsoft\UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\biraz\AppData\Roaming\Microsoft\UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\biraz\AppData\Roaming\ASP.NET\Https
        target: /home/app/.aspnet/https
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\biraz\AppData\Roaming\ASP.NET\Https
        target: /root/.aspnet/https
        read_only: true
        bind: {}
      - type: bind
        source: B:\Programming\Microservices\Self Practice\OrderMicroservice\OrdersMicroservice.API
        target: /app
        bind: {}
      - type: bind
        source: B:\Programming\Microservices\Self Practice\OrderMicroservice
        target: /src
        bind: {}
      - type: bind
        source: C:\Users\biraz\vsdbg\vs2017u5
        target: /remote_debugger
        bind: {}
      - type: bind
        source: C:\Users\biraz\.nuget\packages
        target: /.nuget/packages
        read_only: true
        bind: {}
      - type: bind
        source: C:\Program Files (x86)\Microsoft Visual Studio\Shared\NuGetPackages
        target: /.nuget/fallbackpackages
        read_only: true
        bind: {}
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\18\Community\MSBuild\Sdks\Microsoft.Docker.Sdk\tools\linux-x64\net8.0
        target: /VSTools
        read_only: true
        bind: {}
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\18\Community\Common7\IDE\extensions\Microsoft\managedprojectsystem\HotReload
        target: /HotReloadAgent
        read_only: true
        bind: {}
  postgres-container:
    environment:
      POSTGRES_DB: eCommerceUsers
      POSTGRES_PASSWORD: admin
      POSTGRES_USER: postgres
    image: postgres:13
    networks:
      users-postgres-network: null
    ports:
      - mode: ingress
        target: 5432
        published: "5433"
        protocol: tcp
    volumes:
      - type: bind
        source: B:\Programming\Microservices\Self Practice\OrderMicroservice\OrdersMicroservice.API\postgres-init
        target: /docker-entrypoint-initdb.d
        bind: {}
  products-microservice:
    depends_on:
      mysql-container:
        condition: service_started
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      MYSQL_DATABASE: ecommerceproductsdatabase
      MYSQL_HOST: mysql-container
      MYSQL_PASSWORD: admin
      MYSQL_PORT: "3306"
      MYSQL_USER: root
    image: birazdahalproducts:latest
    networks:
      ecommerce-network: null
      products-mysql-network: null
    ports:
      - mode: ingress
        target: 8080
        published: "6001"
        protocol: tcp
  users-microservice:
    depends_on:
      postgres-container:
        condition: service_started
        required: true
    environment:
      ASPNETCORE_HTTP_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      POSTGRES_DATABASE: eCommerceUsers
      POSTGRES_HOST: postgres-container
      POSTGRES_PASSWORD: admin
      POSTGRES_PORT: "5432"
      POSTGRES_USER: postgres
    image: users-microservice:latest
    networks:
      ecommerce-network: null
      users-postgres-network: null
    ports:
      - mode: ingress
        target: 9090
        published: "5000"
        protocol: tcp
networks:
  ecommerce-network:
    name: dockercompose11062501626633180404_ecommerce-network
    driver: bridge
  orders-mongodb-network:
    name: dockercompose11062501626633180404_orders-mongodb-network
    driver: bridge
  products-mysql-network:
    name: dockercompose11062501626633180404_products-mysql-network
    driver: bridge
  users-postgres-network:
    name: dockercompose11062501626633180404_users-postgres-network
    driver: bridge